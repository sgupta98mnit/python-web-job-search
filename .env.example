# All keys are optional - only set the one(s) for the provider(s) you use.
# Ollama runs locally and does NOT need a key.

OPENAI_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
APP_PASSWORD=
APP_SECRET=

# Search backend defaults to searxng. The web UI can still start a manual
# Serper boost through the API when SERPER_API_KEY is configured.
SEARCH_BACKEND=searxng
SERPER_API_KEY=

# New Relic APM + application log forwarding. Leave NEW_RELIC_LICENSE_KEY blank
# to run without New Relic.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_ENABLED=true
NEW_RELIC_ENVIRONMENT=development
NEW_RELIC_API_APP_NAME=job-search-api
NEW_RELIC_DAEMON_APP_NAME=job-search-daemon
NEW_RELIC_WEB_APP_NAME=job-search-web
NEW_RELIC_INFRA_DISPLAY_NAME=job-search-host
NEW_RELIC_LOG=stdout
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_APPLICATION_LOGGING_ENABLED=true
NEW_RELIC_APPLICATION_LOGGING_FORWARDING_ENABLED=true

# Optional SearXNG throttling overrides. VPS/data-center IPs should run slower.
# Local defaults are 120s between queries and 90s between pages.
SECONDS_BETWEEN_QUERIES=
SECONDS_BETWEEN_PAGES=
THROTTLE_JITTER=
MAX_REQUESTS_PER_MINUTE=
COOLOFF_AFTER_EMPTY_QUERIES=
COOLOFF_SECONDS=

# Email notifications for unsent jobs with score > EMAIL_SCORE_THRESHOLD.
# Sent via Resend (https://resend.com). Free tier sends FROM
# onboarding@resend.dev TO the address that owns the API key. To send
# from your own address, verify a domain at resend.com/domains.
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_TO=sgupta98mnit@outlook.com
EMAIL_SCORE_THRESHOLD=50
EMAIL_FROM=onboarding@resend.dev
RESEND_API_KEY=
# RESEND_API_URL=https://api.resend.com/emails
# RESEND_TIMEOUT=15

# --- JD fetcher (see docs/superpowers/specs/2026-05-26-jd-fetching-design.md) ---
# JD_FETCH_ENABLED=true
# JD_FETCH_TIMEOUT=15
# JD_FETCH_WORKERS=8
# JD_FETCH_PER_HOST_RPS=1.0
# JD_CACHE_TTL_DAYS=30
# JD_MIN_BODY_CHARS=400
# JD_USER_AGENT=Mozilla/5.0 (compatible; jobsearch/1.0; +https://...)
