# Copy this to .env on the VPS and fill in real values.

# App login password for the web UI.
APP_PASSWORD=change-this-long-password

# Stable cookie signing secret. Generate with: openssl rand -hex 32
APP_SECRET=change-this-with-openssl-rand-hex-32

# Set true only when the site is served over HTTPS.
APP_COOKIE_SECURE=false

# Comma-separated browser origins allowed to call the API directly.
# If you use the Next.js proxy only, the default is fine.
APP_CORS_ORIGINS=http://localhost:3000

# Database credentials used by docker-compose.prod.yml.
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=change-this-database-password
POSTGRES_DB=jobsearch

# Bind web to localhost for use behind Nginx/Caddy.
# Use WEB_BIND=0.0.0.0 if you want to access http://SERVER_IP:3000 directly.
WEB_BIND=127.0.0.1
WEB_PORT=3000

# For your sumit-gupta.cloud Caddy setup, deploy under:
# https://sumit-gupta.cloud/projects/job-search
# Leave both blank if deploying this app on its own subdomain.
NEXT_PUBLIC_BASE_PATH=/projects/job-search
NEXT_PUBLIC_API_BASE=/projects/job-search

# LLM/search configuration.
SEARCH_BACKEND=searxng
OPENAI_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
SERPER_API_KEY=

# New Relic APM + application log forwarding. Leave NEW_RELIC_LICENSE_KEY blank
# to run without New Relic.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_ENABLED=true
NEW_RELIC_ENVIRONMENT=production
NEW_RELIC_API_APP_NAME=job-search-api
NEW_RELIC_DAEMON_APP_NAME=job-search-daemon
NEW_RELIC_WEB_APP_NAME=job-search-web
NEW_RELIC_INFRA_DISPLAY_NAME=job-search-host
NEW_RELIC_LOG=stdout
NEW_RELIC_LOG_LEVEL=info
NEW_RELIC_APPLICATION_LOGGING_ENABLED=true
NEW_RELIC_APPLICATION_LOGGING_FORWARDING_ENABLED=true

# Conservative VPS profile for Google-through-SearXNG.
# With jitter, 300 means each query waits roughly 150-450 seconds.
SECONDS_BETWEEN_QUERIES=300
SECONDS_BETWEEN_PAGES=180
THROTTLE_JITTER=0.5
MAX_REQUESTS_PER_MINUTE=1
RETRY_BACKOFF_BASE=30
RETRY_BACKOFF_MAX=300
COOLOFF_AFTER_EMPTY_QUERIES=1
COOLOFF_SECONDS=3600

# Email notifications. The daemon sends one digest after each successful cycle
# for jobs not previously sent to this recipient.
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_TO=sgupta98mnit@outlook.com
EMAIL_SCORE_THRESHOLD=50
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=sgupta98mnit@outlook.com
SMTP_PASSWORD=change-this-mail-password-or-app-password
SMTP_FROM=sgupta98mnit@outlook.com
SMTP_STARTTLS=true

# --- JD fetcher (see docs/superpowers/specs/2026-05-26-jd-fetching-design.md) ---
# JD_FETCH_ENABLED=true
# JD_FETCH_TIMEOUT=15
# JD_FETCH_WORKERS=8
# JD_FETCH_PER_HOST_RPS=1.0
# JD_CACHE_TTL_DAYS=30
# JD_MIN_BODY_CHARS=400
# JD_USER_AGENT=Mozilla/5.0 (compatible; jobsearch/1.0; +https://...)
