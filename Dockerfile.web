FROM node:22-alpine AS deps

WORKDIR /app/web
RUN npm install -g pnpm@9.15.9

COPY web/package.json web/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

FROM node:22-alpine AS builder

WORKDIR /app/web
RUN npm install -g pnpm@9.15.9

ARG NEXT_PUBLIC_BASE_PATH=
ARG NEXT_PUBLIC_API_BASE=
ENV NEXT_PUBLIC_BASE_PATH=$NEXT_PUBLIC_BASE_PATH \
    NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE

COPY --from=deps /app/web/node_modules ./node_modules
COPY web ./
RUN pnpm build

FROM node:22-alpine AS runner

WORKDIR /app/web

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1

RUN npm install -g pnpm@9.15.9 \
    && addgroup --system --gid 1001 nextjs \
    && adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nextjs /app/web/package.json ./package.json
COPY --from=builder --chown=nextjs:nextjs /app/web/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=builder --chown=nextjs:nextjs /app/web/node_modules ./node_modules
COPY --from=builder --chown=nextjs:nextjs /app/web/.next ./.next
COPY --from=builder --chown=nextjs:nextjs /app/web/public ./public

USER nextjs

EXPOSE 3000

CMD ["pnpm", "start"]
